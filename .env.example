# Slack 설정
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# 로컬에서 ngrok 없이 쓰려면: api.slack.com → 앱 → Socket Mode 켜기 →
# Basic Information → App-Level Tokens → connections:write 로 발급한 xapp- 토큰
# SLACK_APP_TOKEN=xapp-your-app-level-token-here
#
# DM에서 봇이 메시지를 받으려면 Slack 앱에 Bot Event `message.im` 과 scope `im:history` 추가 후 재설치
#
# 디버그: 슬랙이 어떤 이벤트를 보내는지 터미널에 찍기 (채널 멘션 문제 확인용)
# LOG_SLACK_EVENTS=1

# 서버 설정
PORT=3000
NODE_ENV=development
# LOG_LEVEL=debug

# 데이터베이스
DB_PATH=./data/slack-bot.db
